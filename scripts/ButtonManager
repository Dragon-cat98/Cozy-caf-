using UnityEngine;
using UnityEngine.UI;
using TMPro;
public class ButtonManager : MonoBehaviour
{

    //variables for general purpose
    [Header("General")]
    public bool level;
    public int levelnumber;

    public bool level2;
     public int levelnumber2;
    GameManager gamemanager;

    //variables for the first upgrade
    [Header("Upgrade 1")]
    public int Cost = 10;
    public TextMeshProUGUI MaxedUPText;
    public Button button;
    Image image;
    public int clicked1 = 0;

    //variables for the second upgrade
    [Header("Upgrade 2")]
    public int cost2 = 20;
    Customer_logic customer_logic;
    Customer_logic2 customer_logic2;
    public int clicked2 = 0;
    public TextMeshProUGUI MaxedUPText2;
    public Button button2;
    Image image2;
    
    // Start is called once before the first execution of Update after the MonoBehaviour is created
    void Start()
    {
        //get the references
        gamemanager = Object.FindAnyObjectByType<GameManager>();
        image = button.GetComponent<Image>();
        customer_logic = Object.FindAnyObjectByType<Customer_logic>();
        customer_logic2 = Object.FindAnyObjectByType<Customer_logic2>();
        image2 = button2.GetComponent<Image>();
    }
    // Update is called once per frame
    void Update()
    {
        if(level == true)
        {
            /*checks if the paleyr has pressed the upgrade button
            if they did the text shows the level of the upgrade based
            on how many times the button was pressed */
            MaxedUPText.text = "UP1: Level " + clicked1;
            levelnumber++;
            level = false;
        }

        if(level2 == true)
        {
            /*checks if the paleyr has pressed the upgrade button
            if they did the text shows the level of the upgrade based
            on how many times the button was pressed */
            MaxedUPText2.text = "UP2: Level " + clicked2;
            levelnumber2++;
            level2 = false;
        }

        /*checks if the player has enough money to upgrade
        if so enables the button and changes the color of the button to white*/
        if(gamemanager.money >= Cost)
        {
            button.interactable = true;
            image.color = Color.white;
        }
        else
        {
            /*if the player doesn't have enough money
            to upgrade disables the button and changes the color of the button to the base color*/
            button.interactable = false;
            
        }

        if(clicked1 >= 5)
        {
            /*if the palyer has done 5 upgrades disables the Upgrade button
            and shows the text "Maxed"*/
           MaxedUPText.text = "Maxed";
           button.interactable = false;
        }
        

        //checks if the player has enough money to upgrade
        if(gamemanager.money >= cost2)
        {
            button2.interactable = true;
            image2.color = Color.white;
        }
        else
        {
            //if the player doesn't have enough money the button doesn't activate
            button2.interactable = false;
        }
        if(clicked2 >= 3)
        {
            //if the player has done 3 upgrades disables the Upgrade button
            //and showthe text "Maxed"
           MaxedUPText2.text = "Maxed";
           button2.interactable = false;
        }

    }
    public void Upgrade1()
    {
        //function that upgrades the shop when button is pressed
        gamemanager.price += 5;
        gamemanager.money -= Cost;
        Cost += 10;
        clicked1++;
        level = true;
        
    }

    public void Upgrade2()
    {
        //function that upgrades the shop when button is pressed
        customer_logic.fixed_time -= 2.0f;
        customer_logic2.fixed_time -= 2.0f;
        gamemanager.money -= cost2;
        cost2 += 15;
        clicked2++;
        level2 = true;
    }
}
