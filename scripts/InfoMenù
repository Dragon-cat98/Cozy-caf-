using UnityEngine;

public class InfoMenu : MonoBehaviour
{
    public GameObject UP_infoMenu;
    public bool isOpen;
    // Start is called once before the first execution of Update after the MonoBehaviour is created
    void Start()
    {
        
    }

    // Update is called once per frame
    void Update()
    {
        
    }

    //function that makes the button open and close the info menù
    public void OpenCloseUPInfoMenu()
    {
        if(isOpen == false)
        {
            UP_infoMenu.SetActive(true);
            isOpen = true;
        }
        else
        {
            UP_infoMenu.SetActive(false);
            isOpen = false;
        }
    }

}
