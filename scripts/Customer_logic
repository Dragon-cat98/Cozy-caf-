using UnityEngine;
using UnityEngine.UI;
using TMPro;
public class Customer_logic : MonoBehaviour
{
    public float speed;
    public Transform target;
    public Transform target2;
    public GameObject Panel;
    public float time;
    public float fixed_time;
    GameManager gamemanager;


    public TextMeshProUGUI Payedtext;
    public GameObject Payed;

    public float fadingPayed_effectTime = 2;

    public float fadingPayed_effect;

    // Start is called once before the first execution of Update after the MonoBehaviour is created
    void Start()
    {
        //get references
        gamemanager = Object.FindAnyObjectByType<GameManager>();
        
    }

    // Update is called once per frame
    void Update()
    {
        //starts a timer
        time -= Time.deltaTime;

        if(time <= 0)
        {
            /*moves the customer towards the counter if the button hasn't been pressed
         otherwise moves the customer away from the counter to the starting position*/
         if(gamemanager.buttonPressed == true)
         {
         transform.position = Vector3.MoveTowards(transform.position, target2.position, speed * Time.deltaTime);
         }
         else
         {
            transform.position = Vector3.MoveTowards(transform.position, target.position, speed * Time.deltaTime);
         }
        }


        //if the customer has been served dispaly teh amount of money he gave
        //and starts a timer 
        if(gamemanager.buttonPressed == true)
        {
            Payedtext.text = "Thanks! +" + gamemanager.price + "¥";
            fadingPayed_effect -= Time.deltaTime;
            Payed.SetActive(true);
        }

        //when the timer runs out the text disappears
        if(fadingPayed_effect <=0)
        {
            Payed.SetActive(false);
        }
        


    }

    void OnTriggerEnter2D(Collider2D other)
    {
        //uses tag to check if customer arrived at the counter
        if(other.CompareTag("Ordine"))
        {
            Debug.Log("Pronto per ordinare");
            Panel.SetActive(true);
        }

       //uses tag to check if customer arrived at the starting position
        if(other.CompareTag("Stop"))
        {
            Debug.Log("Fermato");
            time = fixed_time;
            gamemanager.buttonPressed = false;

            //resets teh timer if the custoemr has reached the starting point
            fadingPayed_effect = fadingPayed_effectTime;
        }
    }
}
